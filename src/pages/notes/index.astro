---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NoteCard from '../../components/NoteCard.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---

<BaseLayout
  title="All Notes"
  description="Every LeetCode problem note by Steven Armenta — sorted by recency. Pattern-first explanations of algorithms and data structures."
>
  <section class="container" style="padding-top: 3rem;">
    <p class="hero-eyebrow" style="margin-bottom: 0.75rem;">The archive</p>
    <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3rem); font-weight: 400; letter-spacing: -0.02em; margin-bottom: 0.5rem;">
      All notes
    </h1>
    <p style="color: var(--ink-soft); margin-bottom: 2.5rem;">
      {notes.length} {notes.length === 1 ? 'note' : 'notes'} so far.
    </p>

    {notes.length === 0 ? (
      <p style="color: var(--ink-mute);">No notes published yet.</p>
    ) : (
      <div>
        {notes.map((entry) => <NoteCard entry={entry} />)}
      </div>
    )}
  </section>
</BaseLayout>
