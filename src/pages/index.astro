---
import BaseLayout from '../layouts/BaseLayout.astro';
import NoteCard from '../components/NoteCard.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 6);

const description =
  "Steven Armenta's personal LeetCode study notes — pattern-first explanations, optimal solutions, and the mental models behind them. Computer Science graduate writing the editorial he wishes he had while learning algorithms.";
---

<BaseLayout
  title="Steven Armenta"
  description={description}
  isHomepage={true}
>
  <section class="hero container">
    <p class="hero-eyebrow">Steven Armenta · San Bernardino, CA</p>
    <h1 class="hero-title">
      Notes from the <em>algorithm</em> trenches.
    </h1>
    <p class="hero-lede">
      I'm a Software Engineer working through Data Structures and Algorithms in a deliberate way — writing the notes I wish I'd had while learning.
    </p>
  </section>

  <section class="container">
    <h2 class="section-heading">Recent notes</h2>
    {notes.length === 0 ? (
      <p style="color: var(--ink-mute); padding: 2rem 0;">
        First note coming soon.
      </p>
    ) : (
      <div>
        {notes.map((entry) => <NoteCard entry={entry} />)}
      </div>
    )}
    <p style="margin-top: 2rem;">
      <a href="/notes/">All notes →</a>
    </p>
  </section>

  <section class="container" style="margin-top: 4rem;">
    <h2 class="section-heading">About</h2>
    <div class="prose">  
      <p>
        I'm <strong>Steven Armenta</strong>, a Southern California–based Software Engineer with a Bachelors in Computer Science from SNHU, currently pursuing my Masters in Artificial Intelligence at UT Austin.
      </p>
      <p>
        This site is my public study journal. I keep notes on the algorithmic
        problems I work through — not just the solutions, but the patterns,
        the wrong turns, and the mental shortcuts that make new problems feel
        familiar.
      </p>
      <p>
        <a href="/about/">More about me →</a>
      </p>
    </div>
  </section>
</BaseLayout>
