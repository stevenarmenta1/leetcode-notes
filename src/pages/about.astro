---
import BaseLayout from '../layouts/BaseLayout.astro';

const description =
  "About Steven Armenta — B.S. Computer Science (SNHU), M.S. Artificial Intelligence candidate at UT Austin, Software Engineer based in San Bernardino, California.";
---

<BaseLayout title="About" description={description}>
  <article class="container" style="padding-top: 3rem;">
    <div class="prose">
      <p class="hero-eyebrow" style="margin-bottom: 0.75rem;">About</p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3rem); font-weight: 400; letter-spacing: -0.02em; margin-bottom: 1.5rem;">
        Steven Armenta
      </h1>

      <p>
        Hi — I'm Steven. I'm based in Southern California, and I document my journey through data structures and algorithms one problem at a time.
      </p>

      <h2>What I do</h2>
      <p>
        I work as a Software Engineer in San Bernardino, California, and also hold a position in Information Technology with a public K–12 school district. I earned my B.S. in Computer Science from Southern New Hampshire University and am currently pursuing an M.S. in Artificial Intelligence at the University of Texas at Austin.
      </p>

      <h2>Why this site exists</h2>
      <p>
        As I've been working on DSA problems I've noticed how hard it is to find relevant good notes to understand DSA concepts.
        I'm writing the notes to share with others looking to learn and grow their problem solving skills. Along with my problems I solve I'll include updates on the things I learn along the way as well. 
      </p>
      <p>
        These notes double as my own form of personal accountability. Public-by-default
        forces me to write more carefully and precisley than I would just for myself.
      </p>

      <h2>How I'd love to hear from you</h2>
      <p>
        Found a sharper way to explain something? Spotted an error? Want to
        compare notes on a problem? Reach out on
        <a href="https://www.linkedin.com/in/stevenarmenta/" target="_blank" rel="noopener">LinkedIn</a>.
      </p>

      <h2>Elsewhere</h2>
      <ul>
        <li><a href="https://www.linkedin.com/in/stevenarmenta/" target="_blank" rel="noopener">LinkedIn</a></li>
        <li><a href="https://github.com/stevenarmenta1/" target="_blank" rel="noopener">Github</a></li>
        <!-- TODO: Add GitHub, Twitter/X, etc. -->
      </ul>
    </div>
  </article>
</BaseLayout>
