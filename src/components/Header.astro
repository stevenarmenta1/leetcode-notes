---
const path = Astro.url.pathname;
const isActive = (p: string) =>
  p === '/' ? path === '/' : path === p || path.startsWith(p);
---

<header class="site-header">
  <div class="container site-header-inner">
    <a href="/" class="site-name">
      Steven Armenta <em>· notes</em>
    </a>
    <nav class="site-nav" aria-label="Primary">
      <a href="/" aria-current={isActive('/') ? 'page' : undefined}>Home</a>
      <a href="/notes/" aria-current={isActive('/notes/') ? 'page' : undefined}>Notes</a>
      <a href="/patterns/" aria-current={isActive('/patterns/') ? 'page' : undefined}>Patterns</a>
      <a href="/about/" aria-current={isActive('/about/') ? 'page' : undefined}>About</a>
    </nav>
  </div>
</header>
